# App
APP_ENV=development

# Postgres
POSTGRES_DB=findog
POSTGRES_USER=findog
POSTGRES_PASSWORD=findog
POSTGRES_PORT=5432
DATABASE_URL=postgresql://findog:findog@localhost:5432/findog

# Backend
BACKEND_PORT=8001
SECRET_KEY=change-me

# Scheduler
SCHEDULER_ENABLED=false
PRICE_CHECK_INTERVAL_MINUTES=360
PLATFORMS_CONFIG_PATH=config/platforms.yaml

# Frontend
FRONTEND_PORT=8002
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
